# ─────────────────────────────────────────────────────────────────────────────
# RoomLensPro — Environment Variables Template
# Copy this file to .env and fill in your Firebase project values.
# .env is in .gitignore — NEVER commit the real .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase — Web App Config
# Get these from: Firebase Console → Project Settings → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY_HERE
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
